set(CMAKE_D_COMPILER "@CMAKE_D_COMPILER@")
set(CMAKE_D_COMPILER_ARG1 "@CMAKE_D_COMPILER_ARG1@")
set(CMAKE_D_RUNTIME  "@CMAKE_D_RUNTIME@")
set(CMAKE_D_ARCHIVE  "@CMAKE_D_ARCHIVE@")
set(CMAKE_D_COMPILER_LOADED 1)

set(CMAKE_D_SOURCE_FILE_EXTENSIONS d)
set(CMAKE_D_LINKER_PREFERENCE 40)
if(WIN32)
    set(CMAKE_D_OUTPUT_EXTENSION .obj)
    set(CMAKE_STATIC_LIBRARY_PREFIX_D "")
    set(CMAKE_STATIC_LIBRARY_SUFFIX_D ".lib")
else()
    set(CMAKE_D_OUTPUT_EXTENSION .o)
    set(CMAKE_STATIC_LIBRARY_PREFIX_D "lib")
    set(CMAKE_STATIC_LIBRARY_SUFFIX_D ".a")
endif()
set(CMAKE_D_OUTPUT_EXTENSION_REPLACE 1)
set(CMAKE_D_COMPILER_ENV_VAR "D_COMPILER")
